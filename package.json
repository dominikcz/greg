{
  "name": "@dominikcz/greg",
  "version": "0.9.0",
  "type": "module",
  "types": "./types/index.d.ts",
  "bin": {
    "greg": "./bin/greg.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
