    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sass-embedded": "^1.97.3",
    "shiki": "^4.0.1",
    "svelte": "^5.53.7",
    "unified": "^11.0.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
