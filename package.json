{
  "name": "@dominikcz/greg",
  "version": "0.9.45",
  "type": "module",
  "types": "./types/index.d.ts",
  "bin": {
    "greg": "bin/greg.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "svelte": "./src/lib/MarkdownDocs/MarkdownDocs.svelte",
      "default": "./src/lib/MarkdownDocs/MarkdownDocs.svelte"
    },
    "./types": "./types/index.d.ts",
    "./components": "./src/lib/components/index.js",
    "./plugins": "./src/lib/MarkdownDocs/index.plugins.js",
    "./svelte.config": "./svelte.config.js"
  },
  "files": [
    "bin",
    "public",
    "scripts/generate-static.js",
    "scripts/build-versions.js",
    "scripts/render-markdown.js",
    "src/lib",
    "types",
    "svelte.config.js",
    "docs/guide",
    "docs/reference",
    "docs/__partials",
    "docs/index.md",
    "docs/incompatibilities.md",
    "fakeDocsGenerator"
  ],
  "scripts": {
    "dev": "node ./bin/greg.js dev",
    "build": "node ./bin/greg.js build",
    "build:static": "node ./bin/greg.js build:static",
    "build:markdown": "node ./bin/greg.js build:markdown",
    "preview": "node ./bin/greg.js preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "fakedocs": "node fakeDocsGenerator/generate_docs.js"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.9",
    "svelte": "^5.55.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@lucide/svelte": "^1.7.0",
    "esbuild": "^0.27.7",
    "fuse.js": "^7.2.0",
    "js-yaml": "^4.1.1",
    "mdsvex": "^0.12.7",
    "mermaid": "^11.14.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sass-embedded": "^1.99.0",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.8.0",
    "sqlite-vec": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "sqlite-vec": {
      "optional": true
    }
  },
  "overrides": {
    "dompurify": ">=3.3.2",
    "immutable": ">=5.1.5",
    "lodash-es": ">=4.18.1"
  }
}
